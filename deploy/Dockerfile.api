FROM golang:1.24-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o api ./apps/api/cmd/server

FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /build/api .
COPY --from=builder /build/internal/database/migrations ./migrations

ENV PORT=8080

EXPOSE 8080

CMD ["./api"]
