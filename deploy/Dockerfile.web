FROM node:22-alpine AS builder

WORKDIR /app

COPY web/admin-studio/package*.json ./
RUN npm ci --no-audit --no-fund

COPY web/admin-studio/ ./
RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/nginx.admin-studio.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
